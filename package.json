{
  "name": "bitburner-typescript-template",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "watch:transpile": "tsc -w --preserveWatchOutput",
    "watch:local": "node build/watch.js",
    "watch:remote": "tsx build/game-bridge.ts",
    "bridge": "tsx build/game-bridge.ts",
    "watch:init": "node build/init.js",
    "watch:all": "concurrently npm:watch:transpile npm:watch:local npm:watch:remote",
    "watch": "pnpm run watch:init && pnpm run watch:all"
  },
  "author": "hydroflame, Hoekstraa, based on work by SlyCedix",
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@typescript-eslint/eslint-plugin": "^5.35.1",
    "@typescript-eslint/parser": "^5.35.1",
    "chokidar": "^3.5.3",
    "concurrently": "^7.4.0",
    "eslint": "^9.23.0",
    "fast-glob": "^3.2.12",
    "globals": "^16.0.0",
    "sync-directory": "^5.1.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.27.0",
    "ws": "^8.21.0",
    "@types/ws": "^8.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  }
}