{
    "include": [
        "src/**/*",
    ],
    "exclude": [
        "src/lib/react.ts",
        "src/experiment.tsx",
        "src/archive",
        "NetscriptDefinitions.d.ts",
    ],
    "compilerOptions": {
        "module": "esnext",
        "target": "esnext",
        "moduleResolution": "bundler",
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "esModuleInterop": true,
        "inlineSourceMap": true,
        "inlineSources": true,
        "strict": true,
        "rootDir": "src/",
        "outDir": "dist/",
        "allowJs": true,
        "jsx": "react",
        "skipLibCheck": true,
        "paths": {
            "@ns": [
                "./NetscriptDefinitions.d.ts"
            ],
            "@react": [
                "./src/lib/react.ts"
            ]
        }
    }
}